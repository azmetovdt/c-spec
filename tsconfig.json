{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "sourceMap": true,


    "noImplicitAny": false,
    "strict": true,
    "skipLibCheck": true,
    "types": ["svelte"] 
  },
  "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"]
}